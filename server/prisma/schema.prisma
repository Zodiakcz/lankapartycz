generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int          @id @default(autoincrement())
  username     String       @unique
  displayName  String
  passwordHash String
  role         String       @default("member") // "admin" | "member"
  approved     Boolean      @default(false)
  createdAt    DateTime     @default(now())

  attendance      Attendance[]
  expenses        Expense[]
  submittedGames  Game[]
}

model Party {
  id          Int          @id @default(autoincrement())
  name        String
  location    String
  startDate   DateTime
  endDate     DateTime
  description   String       @default("")
  notes         String       @default("") @map("spotifyInfo")
  placeAddress  String       @default("")
  placeStatus     String       @default("pending") // "pending" | "booked" | "confirmed"
  advancePerNight Int          @default(0) // doporučená záloha za noc
  createdAt       DateTime     @default(now())

  attendance      Attendance[]
  partyGames      PartyGame[]
  schedule        Schedule[]
  expenses        Expense[]
  packingItems    PackingItem[]
  foodEstimates   FoodEstimate[]
  shoppingItems   ShoppingItem[]
}

model Attendance {
  id        Int      @id @default(autoincrement())
  userId    Int
  partyId   Int
  status    String   @default("maybe") // "confirmed" | "maybe" | "declined"
  arrival   DateTime?
  departure DateTime?
  advance   Float    @default(0) // záloha - advance payment
  settled   Boolean  @default(false) // vyrovnáno - payment confirmed by admin

  user      User     @relation(fields: [userId], references: [id])
  party     Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@unique([userId, partyId])
}

model Game {
  id            Int         @id @default(autoincrement())
  name          String
  source        String      @default("steam") // "steam" | "copied" | "free" | "other"
  sourceNote    String      @default("")
  minPlayers    Int         @default(1)
  maxPlayers    Int?
  imageUrl      String      @default("")
  storeUrl      String      @default("")
  approved      Boolean     @default(true)
  submittedById Int?

  submittedBy   User?       @relation(fields: [submittedById], references: [id])
  partyGames    PartyGame[]
}

model PartyGame {
  id      Int   @id @default(autoincrement())
  partyId Int
  gameId  Int

  party   Party @relation(fields: [partyId], references: [id], onDelete: Cascade)
  game    Game  @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([partyId, gameId])
}

model Schedule {
  id          Int    @id @default(autoincrement())
  partyId     Int
  day         Int    // day number (1, 2, 3...)
  timeSlot    String // "morning" | "afternoon" | "evening" | "night"
  title       String
  description String @default("")
  gameId      Int?

  party       Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)
}

model Expense {
  id          Int    @id @default(autoincrement())
  partyId     Int
  paidByUserId Int
  amount      Float
  description String
  isShared    Boolean @default(true)
  createdAt   DateTime @default(now())

  party       Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)
  paidBy      User   @relation(fields: [paidByUserId], references: [id])
}

model FoodEstimate {
  id              Int    @id @default(autoincrement())
  partyId         Int
  category        String // "hotova_jidla" | "piti" | "sunky" | "syry" | "zelenina" | "parky" | "toustovy_chleb"
  unit            String @default("ks") // "ks" | "l" | "baleni" | "kg"
  perNight        Float  @default(0) // expected consumption per person per night
  purchased       Boolean @default(false)

  party           Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@unique([partyId, category])
}

model ShoppingItem {
  id        Int     @id @default(autoincrement())
  partyId   Int
  name      String
  checked   Boolean @default(false)
  createdAt DateTime @default(now())

  party     Party   @relation(fields: [partyId], references: [id], onDelete: Cascade)
}

model PackingItem {
  id       Int     @id @default(autoincrement())
  name     String
  partyId  Int?    // null = global item, set = party-specific
  category String  @default("general") // "general" | "hardware" | "food" | "other"

  party    Party?  @relation(fields: [partyId], references: [id], onDelete: Cascade)
}

model FaqItem {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}
